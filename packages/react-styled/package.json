{
  "name": "@storacha/console-toolkit-react-styled",
  "version": "0.1.0",
  "description": "Styled authentication components for Storacha Console Toolkit - console-exact UI implementation",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/packages/react-styled/src/index.js",
  "types": "./dist/packages/react-styled/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/packages/react-styled/src/index.js",
      "types": "./dist/packages/react-styled/src/index.d.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsc --build --pretty --verbose && npm run copy-assets",
    "copy-assets": "mkdir -p dist/packages/react-styled/src/assets && cp src/assets/*.svg src/assets/*.jpg dist/packages/react-styled/src/assets/ 2>/dev/null || true",
    "typecheck": "tsc --build --emitDeclarationOnly --pretty --verbose",
    "dev": "npm run copy-assets && tsc --build --watch --preserveWatchOutput",
    "predev": "npm run copy-assets",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "src/styles.css",
    "src/assets",
    "!dist/**/*.js.map"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storacha/console-toolkit.git"
  },
  "author": "Storacha Team",
  "license": "Apache-2.0 OR MIT",
  "dependencies": {
    "@storacha/console-toolkit-react": "workspace:^",
    "@storacha/ui-core": "^2.4.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.0.0",
    "fake-indexeddb": "^5.0.0",
    "happy-dom": "^12.0.0",
    "react": "^18.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0"
  }
}


