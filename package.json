{
  "name": "console-toolkit",
  "version": "0.1.0",
  "private": true,
  "description": "Storacha Console Integration Toolkit - Plug-and-play UI components for seamless integration",
  "packageManager": "pnpm@10.1.0",
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" run build && pnpm --filter \"./examples/*\" --filter \"./integration-guide/*\" run build",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter \"./packages/*\" --filter \"./integration-guide/*\" run typecheck"
  },
  "pnpm": {
    "overrides": {
      "@storacha/ui-core": "^2.4.0",
      "@storacha/ui-react": "^2.9.0"
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@ucanto/interface": "^11.0.1",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=16"
  }
}
